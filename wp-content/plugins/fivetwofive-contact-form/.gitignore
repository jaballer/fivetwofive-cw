# FiveTwoFive Contact Form — keep dev-only artifacts out of the repo.
#
# The runtime Composer autoloader IS committed so the plugin works on a
# git-based deploy without running `composer install`. Dev tooling
# (PHPCS / WPCS, pulled via require-dev) installs locally and is not tracked.
/vendor/*
!/vendor/autoload.php
!/vendor/composer/

# installed.json lists every installed package (dev tooling included) but is
# only read by the Composer CLI, never at runtime — keep it out of the repo.
/vendor/composer/installed.json

# installed.php IS committed: the runtime classmap autoloads
# Composer\InstalledVersions, and that class fatals (require of a missing file)
# if any other Composer-aware plugin in the same WordPress process calls its
# runtime API. Shipping its data file keeps the committed autoloader
# self-consistent. Regenerated --no-dev so it carries no dev-tooling references.

# Node tooling, if ever added.
/node_modules/
