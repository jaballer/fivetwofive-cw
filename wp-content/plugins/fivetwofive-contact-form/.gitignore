# FiveTwoFive Contact Form — keep dev-only artifacts out of the repo.
#
# The runtime Composer autoloader IS committed so the plugin works on a
# git-based deploy without running `composer install`. Dev tooling
# (PHPCS / WPCS, pulled via require-dev) installs locally and is not tracked.
/vendor/*
!/vendor/autoload.php
!/vendor/composer/

# These manifests list every installed package (dev tooling included) and are
# only read by the Composer\InstalledVersions runtime API, which this plugin
# does not use. Excluding them keeps the committed autoloader free of dev-only
# references. (Autoloading verified to work without them.)
/vendor/composer/installed.json
/vendor/composer/installed.php

# Node tooling, if ever added.
/node_modules/
